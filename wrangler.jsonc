{
  "name": "nodewarden",  // 替换为你的 Worker 名称
  "compatibility_date": "2026-03-12",  // 或使用当前日期
  
  // 如果你有静态资源目录
  "assets": {
    "directory": "./dist"  // 确保这个路径存在且包含你的资源文件
  },
  
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
